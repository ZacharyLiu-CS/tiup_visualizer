# TiUP Visualizer 配置文件

# 认证配置
auth:
  # 用户名
  username: "admin"
  # 密码
  password: "easygraph"
  # JWT 密钥 (建议生产环境修改为随机字符串)
  secret_key: "tiup-visualizer-secret-key-change-me-in-production"
  # Token 过期时间 (小时)
  token_expire_hours: 24

# 日志配置
logging:
  # 日志存放路径 (支持绝对路径和相对路径)
  log_dir: "./logs"
  # 日志级别: DEBUG, INFO, WARNING, ERROR
  log_level: "INFO"
  # 单个日志文件最大大小 (MB)
  max_file_size_mb: 10
  # 日志文件保留数量
  backup_count: 5
