APP_NAME="TiUP Visualizer"
DEBUG=True
API_PREFIX="/api/v1"

# Root path when behind a reverse proxy sub-path (leave empty for root)
ROOT_PATH=""

# CORS allowed origins (JSON list format)
# For Nginx proxy on same host, this is usually not needed
# CORS_ORIGINS=["http://localhost","http://your-domain.com"]

# Authentication and logging are configured in config.yaml
# Set TIUP_VISUALIZER_CONFIG env var to specify a custom config path
# Default search paths: ./config.yaml, /etc/tiup-visualizer/config.yaml
